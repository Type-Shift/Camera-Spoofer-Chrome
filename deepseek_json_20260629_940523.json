{
  "manifest_version": 3,
  "name": "HD Virtual Camera Pro",
  "version": "2.1",
  "description": "Advanced virtual camera with live customization.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.mp4", "*.png", "*.jpg"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "HD Virtual Camera"
  }
}